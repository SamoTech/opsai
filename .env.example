# ==============================================
# OpsAI Environment Configuration
# ==============================================

# Application
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql://opsai:opsai_pass@localhost:5432/opsai_db

# Redis
REDIS_URL=redis://localhost:6379/0

# AI / LLM
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key-optional
ANTHROPIC_API_KEY=your-anthropic-api-key-optional
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama3-70b-8192

# GitHub Integration
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
GITHUB_APP_TOKEN=ghp_your-github-pat-for-pr-comments-and-autofix

# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-plan-price-id
STRIPE_TEAM_PRICE_ID=price_your-team-plan-price-id

# OAuth (Google + GitHub)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_OAUTH_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-app-client-secret

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=OpsAI

# Storage (Cloudflare R2 or AWS S3)
STORAGE_BUCKET=opsai-logs
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
